[{"data":1,"prerenderedAt":174},["Reactive",2],{"content-query-RCxjyaa9LX":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"date":10,"tags":11,"slug":13,"draft":6,"readingTime":14,"body":19,"_type":169,"_id":170,"_source":171,"_file":172,"_extension":173},"/articles/nifty-vscode-tricks","articles",false,"","Nifty VScode Tricks","Some vscode tricks I have learned that have helped me a ton","2020-05-21T00:00:00.000Z",[12],"vscode","nifty-vscode-tricks",{"text":15,"minutes":16,"time":17,"words":18},"2 min read",1.1,66000,220,{"type":20,"children":21,"toc":163},"root",[22,31,37,46,69,75,87,92,102,110,115,121,133,141],{"type":23,"tag":24,"props":25,"children":27},"element","h2",{"id":26},"change-color-picker-mode",[28],{"type":29,"value":30},"text","Change Color Picker mode",{"type":23,"tag":32,"props":33,"children":34},"p",{},[35],{"type":29,"value":36},"I have begun to move most of my colors on my website to using HSL and needed an easy way to select colors. I discovered that by clicking on the status bar in the color picker, you can change the color format. At the moment it supports RGB, Hex, and HSL.",{"type":23,"tag":32,"props":38,"children":39},{},[40],{"type":23,"tag":41,"props":42,"children":45},"img",{"alt":43,"src":44},"Color Picker","/img/articles/vscode-color-picker.gif",[],{"type":23,"tag":47,"props":48,"children":50},"callout",{"title":49},"Side note about alpha",[51],{"type":23,"tag":32,"props":52,"children":53},{},[54],{"type":23,"tag":55,"props":56,"children":57},"em",{},[58,60],{"type":29,"value":59},"You won't be able to use this method with colors that have an alpha value. See this ",{"type":23,"tag":61,"props":62,"children":66},"a",{"href":63,"rel":64},"https://github.com/Microsoft/vscode/issues/31644",[65],"nofollow",[67],{"type":29,"value":68},"issue",{"type":23,"tag":24,"props":70,"children":72},{"id":71},"auto-format-the-document-on-save",[73],{"type":29,"value":74},"Auto format the document on save",{"type":23,"tag":32,"props":76,"children":77},{},[78,80,85],{"type":29,"value":79},"I hate unformatted code. It's hard to read, takes long to debug, and as someone who is a bit of a perfectionist, it irks my soul. But alas, VSCode to the rescue again. Deep in the settings, you can your code formatted ",{"type":23,"tag":55,"props":81,"children":82},{},[83],{"type":29,"value":84},"automagically✨",{"type":29,"value":86},".",{"type":23,"tag":32,"props":88,"children":89},{},[90],{"type":29,"value":91},"This setting is in:",{"type":23,"tag":32,"props":93,"children":94},{},[95],{"type":23,"tag":96,"props":97,"children":99},"code",{"className":98},[],[100],{"type":29,"value":101},"Settings > Text Editor > Formatting",{"type":23,"tag":32,"props":103,"children":104},{},[105],{"type":23,"tag":41,"props":106,"children":109},{"alt":107,"src":108},"Picture of Auto-Format setting in VsCode","/img/articles/autoformat.png",[],{"type":23,"tag":32,"props":111,"children":112},{},[113],{"type":29,"value":114},"There's also a setting to format on paste! Great for keeping those Stack Overflow snippets formatted the same as the rest of your code.",{"type":23,"tag":24,"props":116,"children":118},{"id":117},"linting-your-grammer",[119],{"type":29,"value":120},"Linting your grammer",{"type":23,"tag":32,"props":122,"children":123},{},[124,126,131],{"type":29,"value":125},"Okay, this one isn't built into vscode, but it's an amazing plugin I discovered. As a developer ",{"type":23,"tag":55,"props":127,"children":128},{},[129],{"type":29,"value":130},"trying",{"type":29,"value":132}," to get better at writing, this one has been useful. I'm using it right now to write this blog post.",{"type":23,"tag":32,"props":134,"children":135},{},[136],{"type":23,"tag":41,"props":137,"children":140},{"alt":138,"src":139},"Picture of Write Good Linter in VsCode","/img/articles/lint-grammar.png",[],{"type":23,"tag":32,"props":142,"children":143},{},[144,146,153,155,161],{"type":29,"value":145},"Its called ",{"type":23,"tag":61,"props":147,"children":150},{"href":148,"rel":149},"https://marketplace.visualstudio.com/items?itemName=travisthetechie.write-good-linter",[65],[151],{"type":29,"value":152},"Write Good Linter",{"type":29,"value":154}," and you can think of it as the Hemingway editor built into vscode. After installing it, the plugin will detect any unnecessary grammar and put a little ",{"type":23,"tag":156,"props":157,"children":158},"u",{},[159],{"type":29,"value":160},"squiggle",{"type":29,"value":162}," under words that need adjusted.",{"title":7,"searchDepth":164,"depth":164,"links":165},2,[166,167,168],{"id":26,"depth":164,"text":30},{"id":71,"depth":164,"text":74},{"id":117,"depth":164,"text":120},"markdown","content:articles:nifty-vscode-tricks.md","content","articles/nifty-vscode-tricks.md","md",1709151213398]