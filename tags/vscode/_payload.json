[{"data":1,"prerenderedAt":176},["ShallowReactive",2],{"vscode-articles":3},[4],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"date":11,"tags":12,"slug":14,"draft":7,"readingTime":15,"body":20,"_type":170,"_id":171,"_source":172,"_file":173,"_stem":174,"_extension":175},"/articles/nifty-vscode-tricks","articles",false,"","Nifty VScode Tricks","Some vscode tricks I have learned that have helped me a ton","2020-05-21",[13],"vscode","nifty-vscode-tricks",{"text":16,"minutes":17,"time":18,"words":19},"2 min read",1.1,66000,220,{"type":21,"children":22,"toc":164},"root",[23,32,38,47,70,76,88,93,103,111,116,122,134,142],{"type":24,"tag":25,"props":26,"children":28},"element","h2",{"id":27},"change-color-picker-mode",[29],{"type":30,"value":31},"text","Change Color Picker mode",{"type":24,"tag":33,"props":34,"children":35},"p",{},[36],{"type":30,"value":37},"I have begun to move most of my colors on my website to using HSL and needed an easy way to select colors. I discovered that by clicking on the status bar in the color picker, you can change the color format. At the moment it supports RGB, Hex, and HSL.",{"type":24,"tag":33,"props":39,"children":40},{},[41],{"type":24,"tag":42,"props":43,"children":46},"img",{"alt":44,"src":45},"Color Picker","/img/articles/vscode-color-picker.gif",[],{"type":24,"tag":48,"props":49,"children":51},"callout",{"title":50},"Side note about alpha",[52],{"type":24,"tag":33,"props":53,"children":54},{},[55],{"type":24,"tag":56,"props":57,"children":58},"em",{},[59,61],{"type":30,"value":60},"You won't be able to use this method with colors that have an alpha value. See this ",{"type":24,"tag":62,"props":63,"children":67},"a",{"href":64,"rel":65},"https://github.com/Microsoft/vscode/issues/31644",[66],"nofollow",[68],{"type":30,"value":69},"issue",{"type":24,"tag":25,"props":71,"children":73},{"id":72},"auto-format-the-document-on-save",[74],{"type":30,"value":75},"Auto format the document on save",{"type":24,"tag":33,"props":77,"children":78},{},[79,81,86],{"type":30,"value":80},"I hate unformatted code. It's hard to read, takes long to debug, and as someone who is a bit of a perfectionist, it irks my soul. But alas, VSCode to the rescue again. Deep in the settings, you can your code formatted ",{"type":24,"tag":56,"props":82,"children":83},{},[84],{"type":30,"value":85},"automagically✨",{"type":30,"value":87},".",{"type":24,"tag":33,"props":89,"children":90},{},[91],{"type":30,"value":92},"This setting is in:",{"type":24,"tag":33,"props":94,"children":95},{},[96],{"type":24,"tag":97,"props":98,"children":100},"code",{"className":99},[],[101],{"type":30,"value":102},"Settings > Text Editor > Formatting",{"type":24,"tag":33,"props":104,"children":105},{},[106],{"type":24,"tag":42,"props":107,"children":110},{"alt":108,"src":109},"Picture of Auto-Format setting in VsCode","/img/articles/autoformat.png",[],{"type":24,"tag":33,"props":112,"children":113},{},[114],{"type":30,"value":115},"There's also a setting to format on paste! Great for keeping those Stack Overflow snippets formatted the same as the rest of your code.",{"type":24,"tag":25,"props":117,"children":119},{"id":118},"linting-your-grammer",[120],{"type":30,"value":121},"Linting your grammer",{"type":24,"tag":33,"props":123,"children":124},{},[125,127,132],{"type":30,"value":126},"Okay, this one isn't built into vscode, but it's an amazing plugin I discovered. As a developer ",{"type":24,"tag":56,"props":128,"children":129},{},[130],{"type":30,"value":131},"trying",{"type":30,"value":133}," to get better at writing, this one has been useful. I'm using it right now to write this blog post.",{"type":24,"tag":33,"props":135,"children":136},{},[137],{"type":24,"tag":42,"props":138,"children":141},{"alt":139,"src":140},"Picture of Write Good Linter in VsCode","/img/articles/lint-grammar.png",[],{"type":24,"tag":33,"props":143,"children":144},{},[145,147,154,156,162],{"type":30,"value":146},"Its called ",{"type":24,"tag":62,"props":148,"children":151},{"href":149,"rel":150},"https://marketplace.visualstudio.com/items?itemName=travisthetechie.write-good-linter",[66],[152],{"type":30,"value":153},"Write Good Linter",{"type":30,"value":155}," and you can think of it as the Hemingway editor built into vscode. After installing it, the plugin will detect any unnecessary grammar and put a little ",{"type":24,"tag":157,"props":158,"children":159},"u",{},[160],{"type":30,"value":161},"squiggle",{"type":30,"value":163}," under words that need adjusted.",{"title":8,"searchDepth":165,"depth":165,"links":166},2,[167,168,169],{"id":27,"depth":165,"text":31},{"id":72,"depth":165,"text":75},{"id":118,"depth":165,"text":121},"markdown","content:articles:nifty-vscode-tricks.md","content","articles/nifty-vscode-tricks.md","articles/nifty-vscode-tricks","md",1738345630966]